<svg width="400" height="250" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad-industry" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#06b6d4;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0891b2;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="400" height="250" fill="url(#grad-industry)"/>
  <rect x="20" y="20" width="360" height="210" fill="white" rx="15" stroke="#06b6d4" stroke-width="3"/>
  <text x="200" y="50" text-anchor="middle" fill="#06b6d4" font-size="20" font-weight="bold">1087X产业升级</text>
  <rect x="40" y="70" width="320" height="60" fill="#f0f0f0" rx="10" stroke="#06b6d4" stroke-width="2"/>
  <text x="200" y="95" text-anchor="middle" fill="#333" font-size="12">技术革新 · 标准化发展</text>
  <text x="200" y="115" text-anchor="middle" fill="#666" font-size="10">产业链全面升级</text>
  <rect x="50" y="150" width="80" height="40" fill="#06b6d4" opacity="0.2" rx="5"/>
  <text x="90" y="175" text-anchor="middle" fill="#06b6d4" font-size="10" font-weight="bold">上游</text>
  <text x="90" y="185" text-anchor="middle" fill="#666" font-size="8">供应链</text>
  <rect x="160" y="150" width="80" height="40" fill="#0891b2" opacity="0.2" rx="5"/>
  <text x="200" y="175" text-anchor="middle" fill="#0891b2" font-size="10" font-weight="bold">中游</text>
  <text x="200" y="185" text-anchor="middle" fill="#666" font-size="8">生产加工</text>
  <rect x="270" y="150" width="80" height="40" fill="#06b6d4" opacity="0.2" rx="5"/>
  <text x="310" y="175" text-anchor="middle" fill="#06b6d4" font-size="10" font-weight="bold">下游</text>
  <text x="310" y="185" text-anchor="middle" fill="#666" font-size="8">销售服务</text>
</svg>
