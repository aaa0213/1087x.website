<svg width="400" height="250" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad-safety" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#10b981;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#059669;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="400" height="250" fill="url(#grad-safety)"/>
  <rect x="20" y="20" width="360" height="210" fill="white" rx="15" stroke="#10b981" stroke-width="3"/>
  <text x="200" y="50" text-anchor="middle" fill="#10b981" font-size="20" font-weight="bold">1087X安全评估</text>
  <rect x="40" y="70" width="320" height="60" fill="#f0f0f0" rx="10" stroke="#10b981" stroke-width="2"/>
  <text x="200" y="95" text-anchor="middle" fill="#333" font-size="12">毒理学研究 · 临床试验</text>
  <text x="200" y="115" text-anchor="middle" fill="#666" font-size="10">安全性显著提升</text>
  <circle cx="100" cy="170" r="25" fill="#10b981" opacity="0.3"/>
  <text x="100" y="175" text-anchor="middle" fill="#10b981" font-size="12" font-weight="bold">92%</text>
  <text x="100" y="188" text-anchor="middle" fill="#666" font-size="10">耐受性</text>
  <circle cx="200" cy="170" r="25" fill="#059669" opacity="0.3"/>
  <text x="200" y="175" text-anchor="middle" fill="#059669" font-size="12" font-weight="bold">80%</text>
  <text x="200" y="188" text-anchor="middle" fill="#666" font-size="10">风险降低</text>
  <circle cx="300" cy="170" r="25" fill="#10b981" opacity="0.3"/>
  <text x="300" y="175" text-anchor="middle" fill="#10b981" font-size="12" font-weight="bold">3%</text>
  <text x="300" y="188" text-anchor="middle" fill="#666" font-size="10">停用率</text>
</svg>
