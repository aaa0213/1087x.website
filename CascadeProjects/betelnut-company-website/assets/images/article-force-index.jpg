<svg width="400" height="250" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad-force" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ec4899;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f97316;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="400" height="250" fill="url(#grad-force)"/>
  <rect x="20" y="20" width="360" height="210" fill="white" rx="15" stroke="#ec4899" stroke-width="3"/>
  <text x="200" y="50" text-anchor="middle" fill="#ec4899" font-size="20" font-weight="bold">1087X原力指数</text>
  <rect x="40" y="70" width="320" height="60" fill="#f0f0f0" rx="10" stroke="#ec4899" stroke-width="2"/>
  <text x="200" y="95" text-anchor="middle" fill="#333" font-size="12">量化评价体系 · 品质标准</text>
  <text x="200" y="115" text-anchor="middle" fill="#666" font-size="10">科学精准的品质控制</text>
  <circle cx="80" cy="170" r="20" fill="#ec4899" opacity="0.3"/>
  <text x="80" y="175" text-anchor="middle" fill="#ec4899" font-size="10" font-weight="bold">40%</text>
  <text x="80" y="185" text-anchor="middle" fill="#666" font-size="8">有效成分</text>
  <circle cx="160" cy="170" r="20" fill="#f97316" opacity="0.3"/>
  <text x="160" y="175" text-anchor="middle" fill="#f97316" font-size="10" font-weight="bold">30%</text>
  <text x="160" y="185" text-anchor="middle" fill="#666" font-size="8">口感强度</text>
  <circle cx="240" cy="170" r="20" fill="#ec4899" opacity="0.3"/>
  <text x="240" y="175" text-anchor="middle" fill="#ec4899" font-size="10" font-weight="bold">20%</text>
  <text x="240" y="185" text-anchor="middle" fill="#666" font-size="8">持久度</text>
  <circle cx="320" cy="170" r="20" fill="#f97316" opacity="0.3"/>
  <text x="320" y="175" text-anchor="middle" fill="#f97316" font-size="10" font-weight="bold">10%</text>
  <text x="320" y="185" text-anchor="middle" fill="#666" font-size="8">安全性</text>
</svg>
