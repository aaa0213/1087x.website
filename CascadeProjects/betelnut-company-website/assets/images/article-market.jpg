<svg width="400" height="250" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad-market" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f97316;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#ec4899;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="400" height="250" fill="url(#grad-market)"/>
  <rect x="20" y="20" width="360" height="210" fill="white" rx="15" stroke="#f97316" stroke-width="3"/>
  <text x="200" y="50" text-anchor="middle" fill="#f97316" font-size="20" font-weight="bold">1087X市场前景</text>
  <rect x="40" y="70" width="320" height="60" fill="#f0f0f0" rx="10" stroke="#f97316" stroke-width="2"/>
  <text x="200" y="95" text-anchor="middle" fill="#333" font-size="12">市场占有率预测分析</text>
  <text x="200" y="115" text-anchor="middle" fill="#666" font-size="10">消费升级 · 品质选择</text>
  <rect x="50" y="150" width="300" height="50" fill="#f97316" opacity="0.1" rx="5"/>
  <rect x="50" y="150" width="45" height="50" fill="#f97316" opacity="0.3" rx="5"/>
  <text x="72" y="180" text-anchor="middle" fill="#f97316" font-size="10" font-weight="bold">15%</text>
  <text x="72" y="192" text-anchor="middle" fill="#666" font-size="8">2024</text>
  <rect x="120" y="150" width="75" height="50" fill="#f97316" opacity="0.3" rx="5"/>
  <text x="157" y="180" text-anchor="middle" fill="#f97316" font-size="10" font-weight="bold">25%</text>
  <text x="157" y="192" text-anchor="middle" fill="#666" font-size="8">2025</text>
  <rect x="220" y="150" width="130" height="50" fill="#f97316" opacity="0.3" rx="5"/>
  <text x="285" y="180" text-anchor="middle" fill="#f97316" font-size="10" font-weight="bold">48%</text>
  <text x="285" y="192" text-anchor="middle" fill="#666" font-size="8">2028</text>
</svg>
